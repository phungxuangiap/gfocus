{
  "expo": {
    "name": "GFocus",
    "slug": "g-focus",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "gfocus",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#eeeeea"
      },
      "package": "com.alexgi0806.gfocus",
      "permissions": [
        "USE_FULL_SCREEN_INTENT"
      ]
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#00000000",
      "enforceContrast": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/checkin_sound.mp3"
          ]
        }
      ],
      "expo-asset"
    ]
  }
}
